// Definição dos pinos
const int trigPin = 9;
const int echoPin = 10;
const int buzzerPin = 11;

// Variáveis para cálculo
long duracao;
int distancia;
int intervalo;

void setup() {
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  pinMode(buzzerPin, OUTPUT);
  Serial.begin(9600);
}

void loop() {
  // Limpa o trigPin
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  // Ativa o sensor por 10 microssegundos
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  // Lê o tempo de resposta do eco
  duracao = pulseIn(echoPin, HIGH);

  // Calcula a distância em cm
  distancia = duracao * 0.034 / 2;

  // Lógica do Sensor de Ré
  if (distancia <= 5) {
    // Menos de 5cm: Som contínuo
    digitalWrite(buzzerPin, HIGH);
  } 
  else if (distancia <= 40) {
    // Entre 5cm e 40cm: Bipa proporcionalmente à distância
    // Quanto menor a distância, menor o intervalo (mais rápido)
    intervalo = map(distancia, 5, 40, 50, 400); 
    
    digitalWrite(buzzerPin, HIGH);
    delay(50); // Tempo do bipe curto
    digitalWrite(buzzerPin, LOW);
    delay(intervalo); 
  } 
  else {
    // Fora do alcance: Buzzer desligado
    digitalWrite(buzzerPin, LOW);
  }

  // Debug no Monitor Serial
  Serial.print("Distancia: ");
  Serial.print(distancia);
  Serial.println(" cm");
}
